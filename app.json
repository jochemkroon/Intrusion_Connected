  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Alarm cleared",
          "nl": "Alarm opgeheven"
        },
        "hint": {
          "en": "This card triggers when the alarm is cleared",
          "nl": "Deze kaart wordt getriggerd wanneer het alarm wordt opgeheven"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "alarm_cleared"
      },
      {
        "title": {
          "en": "System alert active",
          "nl": "Systeem alarm actief"
        },
        "hint": {
          "en": "This card triggers when a system alert becomes active (Tamper, Fault, etc.)",
          "nl": "Deze kaart wordt getriggerd wanneer een systeem alarm actief wordt (Sabotage, Storing, etc.)"
