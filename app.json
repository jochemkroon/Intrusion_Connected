        "tokens": [
          {
            "name": "alert_type",
            "type": "string",
            "title": {
              "en": "Alert type",
              "nl": "Alarm type"
            },
            "example": {
              "en": "Controller Cabinet Tamper",
              "nl": "Controller Cabinet Tamper"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "system_alert_active"
      },
      {
        "title": {
          "en": "System alert cleared",
          "nl": "Systeem alarm opgelost"
        },
        "hint": {
          "en": "This card triggers when a system alert is cleared",
          "nl": "Deze kaart wordt getriggerd wanneer een systeem alarm wordt opgelost"
        },
        "tokens": [
          {
            "name": "alert_type",
            "type": "string",
            "title": {
              "en": "Alert type",
              "nl": "Alarm type"
            },
            "example": {
              "en": "Controller Cabinet Tamper",
              "nl": "Controller Cabinet Tamper"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "system_alert_cleared"
      },
      {
        "title": {
          "en": "System armed",
          "nl": "Systeem ingeschakeld"
        },
        "hint": {
          "en": "This card triggers when the alarm system is armed (fully or partially)",
          "nl": "Deze kaart wordt getriggerd wanneer het alarmsysteem wordt ingeschakeld (volledig of deels)"
        },
        "tokens": [
          {
            "name": "mode",
            "type": "string",
            "title": {
              "en": "Mode",
              "nl": "Modus"
            },
            "example": {
              "en": "armed",
              "nl": "armed"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "system_armed"
