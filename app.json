        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "has_active_alarm"
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Alarm Panel"
      },
      "class": "homealarm",
      "capabilities": [
        "homealarm_state",
        "alarm_generic",
        "alarm_message",
        "zone_status"
      ],
      "capabilitiesOptions": {
        "alarm_message": {
          "title": {
            "en": "System Alert",
            "nl": "Systeem Alarm"
          },
          "getable": true,
          "setable": false
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/panel/assets/images/small.png",
        "large": "/drivers/panel/assets/images/large.png",
        "xlarge": "/drivers/panel/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "login",
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Connection Settings"
          },
          "children": [
            {
              "id": "panel_type",
              "type": "dropdown",
              "label": {
                "en": "Alarm Panel Type"
              },
              "value": "spc4200",
              "values": [
                {
                  "id": "spc4200",
                  "label": {
                    "en": "SPC 4200/4300"
                  }
                },
                {
                  "id": "spc5000",
                  "label": {
                    "en": "SPC 5200/5300"
                  }
                },
                {
                  "id": "spc6000",
                  "label": {
                    "en": "SPC 6300"
                  }
                },
                {
                  "id": "generic",
                  "label": {
                    "en": "Generic (Other)"
                  }
                }
              ],
              "hint": {
                "en": "Select your alarm panel model"
              }
            },
            {
              "id": "host",
              "type": "text",
              "label": {
                "en": "IP Address or Hostname"
              },
              "value": "",
              "hint": {
                "en": "The IP address or hostname of your alarm panel"
              }
            },
            {
              "id": "https",
              "type": "checkbox",
              "label": {
                "en": "Use HTTPS"
              },
              "value": false,
              "hint": {
                "en": "Enable HTTPS connection (port 443 instead of 80)"
              }
            },
            {
              "id": "username",
              "type": "text",
              "label": {
                "en": "User ID"
              },
              "value": ""
            },
            {
              "id": "password",
              "type": "password",
              "label": {
                "en": "Password"
              },
              "value": ""
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Advanced Settings"
          },
          "children": [
            {
              "id": "poll_interval",
              "type": "number",
              "label": {
                "en": "Poll Interval (seconds)"
              },
              "value": 5,
              "min": 1,
              "max": 60,
              "hint": {
                "en": "How often to check the panel status"
              }
            }
          ]
        }
      ],
      "id": "panel"
    }
