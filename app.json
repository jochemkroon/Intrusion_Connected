        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "zone_alarm_cleared"
      },
      {
        "title": {
          "en": "Zone alarm triggered",
          "nl": "Zone alarm geactiveerd"
        },
        "hint": {
          "en": "This card triggers when a zone alarm is triggered (intrusion detection)",
          "nl": "Deze kaart wordt getriggerd wanneer een zone alarm afgaat (inbraakdetectie)"
        },
        "tokens": [
          {
            "name": "zone_number",
            "type": "number",
            "title": {
              "en": "Zone number",
              "nl": "Zone nummer"
            },
            "example": 2
          },
          {
            "name": "zone_name",
            "type": "string",
            "title": {
              "en": "Zone name",
              "nl": "Zone naam"
            },
            "example": {
              "en": "PIR Entree",
              "nl": "PIR Entree"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          }
        ],
        "id": "zone_alarm_triggered"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Alarm message contains",
          "nl": "Alarmbericht bevat"
        },
        "hint": {
          "en": "Check if the current alarm message contains specific text",
          "nl": "Controleer of het huidige alarmbericht specifieke tekst bevat"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          },
          {
            "type": "text",
            "name": "text",
            "title": {
              "en": "Text",
              "nl": "Tekst"
            },
            "placeholder": {
              "en": "e.g. Tamper",
              "nl": "bijv. Tamper"
            }
          }
        ],
        "id": "alarm_message_contains"
      },
      {
        "title": {
          "en": "Alarm message is",
          "nl": "Alarmbericht is"
        },
        "hint": {
          "en": "Check if the current alarm message matches exactly",
          "nl": "Controleer of het huidige alarmbericht exact overeenkomt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=panel"
          },
          {
            "type": "text",
            "name": "message",
            "title": {
              "en": "Message",
              "nl": "Bericht"
            },
            "placeholder": {
              "en": "e.g. Controller Cabinet Tamper",
              "nl": "bijv. Controller Cabinet Tamper"
            }
          }
        ],
        "id": "alarm_message_equals"
      },
      {
        "title": {
          "en": "Has active alarm",
          "nl": "Heeft actief alarm"
        },
        "hint": {
          "en": "Check if there is currently an active alarm message",
          "nl": "Controleer of er momenteel een actief alarmbericht is"
