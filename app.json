  "capabilities": {
    "alarm_message": {
      "type": "string",
      "title": {
        "en": "System Alert",
        "nl": "Systeem Alarm"
      },
      "desc": {
        "en": "Current system alert (Tamper, Fault, etc.)",
        "nl": "Huidige systeem alarm (Sabotage, Storing, etc.)"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg"
    },
    "zone_status": {
      "type": "string",
      "title": {
        "en": "Zone Status",
        "nl": "Zone Status"
      },
      "desc": {
        "en": "Number of open zones",
        "nl": "Aantal open zones"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg"
    }
  }
